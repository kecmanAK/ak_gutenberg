root = true

[*.{php,js,css,md,txt,yml,yaml}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.php]
indent_style = space
indent_size = 4

[*.{js,css,yml,yaml}]
indent_style = space
indent_size = 2

[*.txt]
indent_style = space
indent_size = 2
